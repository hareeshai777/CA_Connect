# =============================================
# SERVER CONFIG
# =============================================
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# In production, set to your deployed frontend URL, e.g.:
# FRONTEND_URL=https://your-app.vercel.app
# Comma-separated list of additional allowed origins (optional):
# ALLOWED_ORIGINS=https://www.yourdomain.com,https://yourdomain.com

# =============================================
# DATABASE
# =============================================
DATABASE_URL="mysql://root:password@localhost:3306/ca_saas_db"

# =============================================
# JWT SECRETS
# =============================================
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# =============================================
# GOOGLE OAUTH
# =============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# =============================================
# GOOGLE WORKSPACE (CALENDAR + MEET)
# =============================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"
GOOGLE_CALENDAR_ID=primary

# =============================================
# CLOUDINARY (FILE STORAGE)
# =============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =============================================
# RAZORPAY (PAYMENTS)
# =============================================
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# =============================================
# WHATSAPP BUSINESS API (Meta)
# =============================================
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# =============================================
# GOOGLE GEMINI AI
# =============================================
GEMINI_API_KEY=your_gemini_api_key

# =============================================
# EMAIL (NODEMAILER / SMTP)
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="CA SaaS Platform <noreply@casaas.com>"

# =============================================
# AWS S3 (ALTERNATIVE TO CLOUDINARY)
# =============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=ca-saas-documents

# =============================================
# PLATFORM CONFIG
# =============================================
CA_ONBOARDING_FEE=49900
PLATFORM_COMMISSION_PERCENT=10
